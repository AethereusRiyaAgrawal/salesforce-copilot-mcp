# Salesforce Connected App credentials
SF_LOGIN_URL=https://login.salesforce.com
SF_API_VERSION=v59.0
SF_CLIENT_ID=                        # Required — Connected App consumer key
SF_CLIENT_SECRET=                    # Required — Connected App consumer secret

# Server
PORT=3000
EXTERNAL_BASE_URL=https://<your-app>.onrender.com   # Must match Salesforce callback URI

# API key gate — Copilot must send: Authorization: Bearer <value>
# Generate any strong random string, e.g.: openssl rand -hex 32
MCP_API_KEY=

# User identity (required when not using Azure App Service Authentication).
# On Render there is no header injection, so set these to identify the user
# whose Salesforce session is stored. For single-user personal use these can
# stay set permanently. Remove only if running behind Azure App Service Auth.
DEV_BYPASS_USER_ID=
DEV_BYPASS_USER_NAME=
DEV_BYPASS_TENANT_ID=render
