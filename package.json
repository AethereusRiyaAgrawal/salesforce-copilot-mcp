{
  "name": "salesforce-claude-mcp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc",
    "start": "node dist/server.js",
    "start:stdio": "node dist/stdio.js",
    "dev": "node dist/server.js",
    "dev:stdio": "node --env-file=.env --watch dist/stdio.js",
    "dev:build": "node ./node_modules/typescript/bin/tsc --watch",
    "type-check": "node ./node_modules/typescript/bin/tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
